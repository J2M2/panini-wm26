# Copy this to .env and fill in real values. .env is gitignored.

# Base URL of the deployed app
API_BASE=https://panini-wm26.fly.dev

# Admin token — must match PANINI_ADMIN_TOKEN set on Fly.io
# Set it with: flyctl secrets set PANINI_ADMIN_TOKEN="some-long-random-string" -a panini-wm26
PANINI_ADMIN_TOKEN=replace-me
